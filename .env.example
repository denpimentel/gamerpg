# PixelLab — geração de pixel-art por IA (api.pixellab.ai/v2). Docs: https://api.pixellab.ai/v2/docs
PIXELLAB_API_KEY="your_pixellab_api_key_here"

# Múltiplas keys p/ roteamento por saldo (opcional)
# Formato: nome:key;nome:key — o roteador (scripts/pixellab-route.py) usa a com mais saldo.
PIXELLAB_KEYS="Main:key1;Account2:key2"

# OpenRouter — geração de imagem (gpt-image) e LLMs de apoio
OPENROUTER_API_KEY="your_openrouter_api_key_here"
